# Secrets
.env
.env.*
!.env.example
# Deploy secrets (Kustomize secretGenerator inputs); the .example is committed, the real one isn't.
deploy/kustomize/overlays/*/secret.env

# Runtime scratch (per-session state, generated configs, captured logs, optional repo clones)
workspace/
!workspace/.gitkeep

# QA-fleet runtime output (per-agent reports + regenerated aggregates). The curated, deduplicated
# record lives in docs/QA_FINDINGS_LOG.md (tracked); these are throwaway and regenerate on each run.
docs/findings/
docs/AGENT_FINDINGS.md
docs/AGENT_FINDINGS_ALL.md
docs/AGENT_FINDINGS_REAL.md

# Local-only QA-fleet durable source (machine-specific absolute paths; kept out of shared history).
tools/qa-fleet/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
# Coverage artifacts (Phase 14 quality gates)
.coverage
.coverage.*
coverage.xml
htmlcov/

# Logs
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
