# Secrets
.env
# Deploy secrets (Kustomize secretGenerator inputs); the .example is committed, the real one isn't.
deploy/kustomize/overlays/*/secret.env

# Runtime scratch (per-session state, generated configs, captured logs, optional repo clones)
workspace/
!workspace/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
# graphify code-nav output (dev-only scratch/cache)
graphify-out/
# Coverage artifacts (Phase 14 quality gates)
.coverage
.coverage.*
coverage.xml
htmlcov/

# Logs
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
