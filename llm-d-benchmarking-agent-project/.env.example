# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# --- LLM provider -----------------------------------------------------------
# The agent runs on the Claude Agent SDK, using your Claude SUBSCRIPTION (e.g. a Max plan)
# instead of a metered API key. Auth comes from the locally-installed `claude` CLI being
# logged in (`claude` then /login). No API key needed: leave ANTHROPIC_API_KEY UNSET (a stray
# one would force per-token API billing — the provider blanks it for the CLI to be safe). The
# SDK is used purely for inference; all of its built-in tools (Bash/Read/Write/Web/…) stay
# disabled and the app's own approval-gated tools + agent loop are unchanged. Requires the
# `claude-agent-sdk` package (in deps).
# EASIEST: run ./scripts/setup-claude-plan.sh — it walks the login, picks the model, writes
# this block for you, and verifies with one tiny test call.
LLM_PROVIDER=claude-agent-sdk
AGENT_SDK_MODEL=claude-sonnet-5
# Reasoning quality. The defaults match the Sonnet-class behavior of Claude Code: deep-reasoning
# "high" effort + adaptive extended thinking (Claude decides when/how much to think).
#   AGENT_SDK_EFFORT   = low | medium | high | xhigh | max          (default: high)
#   AGENT_SDK_THINKING = adaptive | <budget_tokens, e.g. 4096> | off (default: adaptive)
AGENT_SDK_EFFORT=high
AGENT_SDK_THINKING=adaptive
# Optional: explicit path to the `claude` CLI. Leave empty to auto-discover it on PATH.
CLAUDE_CLI_PATH=
# Claude subscription OAuth token from `claude setup-token` (a ~1-year headless token). This is the
# PRIMARY auth for the CLUSTER-SERVICE deploy path (scripts/install_service.sh --oauth-token / Helm
# secret.claudeCodeOauthToken) — the baked `claude` CLI reads it from this env var with no browser or
# TTY. Optional locally: the logged-in `claude` CLI is used instead, so leave this empty on a dev box.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Paths ------------------------------------------------------------------
# Parent dir that contains (or will contain) the llm-d and llm-d-benchmark repos.
# Defaults to the parent of this project folder.
REPOS_DIR=

# Where the agent writes runtime scratch (sessions, generated configs, logs).
# Defaults to ./workspace
WORKSPACE_DIR=

# --- Optional ---------------------------------------------------------------
# HuggingFace token, only needed for gated models on real (non-sim) deploys.
# Provided to the backend; never echoed to the browser or logs.
HF_TOKEN=

# Server bind
HOST=127.0.0.1
PORT=8000

# --- Orchestrator (in-cluster benchmark Jobs) -------------------------------
# Container image carrying the llmdbenchmark CLI, used for ORCHESTRATED (K8s Job)
# benchmark runs. Empty -> orchestrate_benchmark_run refuses and the agent uses the
# local CLI path instead. The packaging deploy (deploy/helm) sets this.
ORCHESTRATOR_IMAGE=
# ServiceAccount the orchestrated benchmark Jobs run under. The deploy sets this to the
# least-privilege SA the chart creates; empty -> the namespace default SA (local dev).
ORCHESTRATOR_SERVICE_ACCOUNT=
# Optional: your own llm-d observability dashboard (the upstream `--monitoring` Grafana). When
# set, the live resource panel that opens during a run EMBEDS this dashboard alongside the
# agent's own kubectl-top view. Empty -> the panel shows only the agent's own table/sparklines.
GRAFANA_DASHBOARD_URL=

# --- Simulate (dry run) -----------------------------------------------------
# When 1, the agent drives the WHOLE workflow but EXECUTES NOTHING: every command
# is a no-op returning synthetic success, per-command approvals are skipped, and a
# synthetic benchmark report is produced. Lets you watch the agent walk a guide
# end-to-end without touching a cluster. Default 0 (real execution).
SIMULATE=0

# CORS: comma-separated allowed origins for the browser fetch surface. Empty (default) installs
# NO CORS middleware (today's behavior). e.g. CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_ORIGINS=

# Public base URL for "share a chat" links. Empty (default) -> links are relative (/share/<token>)
# and the browser uses its own origin (already the public host when you open the app via a public
# URL/tunnel). Set this to a public origin to mint ABSOLUTE links you can hand to a friend, e.g.
#   SHARE_BASE_URL=https://abc123.trycloudflare.com   (a `cloudflared tunnel --url ...` URL)
# SECURITY: this service has no Bearer auth — exposing it publicly so friends can open share
# links also exposes the WHOLE agent to anyone who can reach the host.
SHARE_BASE_URL=

# --- Workspace lifecycle (Phase 18) — retention/GC + startup self-check ------
# Bound the growth of per-session/run scratch + the history store. Each cap applies independently
# per area (sessions/, runs/, jobs/, history/), removing the OLDEST first; 0 = UNLIMITED. An
# active/running session is NEVER pruned. Defaults DON'T surprise existing users: only a generous
# 500-items/area ceiling is on; age + bytes are unlimited (no time/size deletion out of the box).
# See knowledge/workspace_lifecycle.md. Set these to enable active reclamation to fit your disk.
RETENTION_MAX_AGE_DAYS=0
RETENTION_MAX_ITEMS=500
RETENTION_MAX_BYTES=0
# Run the retention GC once at startup (default true; a no-op under the defaults above).
RETENTION_GC_ON_STARTUP=true
# Run the startup config self-check (workspace writable, provider coherent, repos resolvable,
# auth coherent) and fold it into /readyz (200 ready / 503 not-ready, with structured reasons).
STARTUP_SELF_CHECK=true
