# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# --- LLM provider -----------------------------------------------------------
# Which provider the agent talks to: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Model id; defaults to a current Claude model if unset
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI-compatible (used when LLM_PROVIDER=openai). BASE_URL may point at any
# OpenAI-compatible server, including a self-hosted vLLM / llm-d endpoint.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- Paths ------------------------------------------------------------------
# Parent dir that contains (or will contain) the llm-d and llm-d-benchmark repos.
# Defaults to the parent of this project folder.
REPOS_DIR=

# Where the agent writes runtime scratch (sessions, generated configs, logs).
# Defaults to ./workspace
WORKSPACE_DIR=

# --- Optional ---------------------------------------------------------------
# HuggingFace token, only needed for gated models on real (non-sim) deploys.
# Provided to the backend; never echoed to the browser or logs.
HF_TOKEN=

# Server bind
HOST=127.0.0.1
PORT=8000

# --- Orchestrator (in-cluster benchmark Jobs) -------------------------------
# Container image carrying the llmdbenchmark CLI, used for ORCHESTRATED (K8s Job)
# benchmark runs. Empty -> orchestrate_benchmark_run refuses and the agent uses the
# local CLI path instead. The packaging deploy (deploy/helm, deploy/kustomize) sets this.
ORCHESTRATOR_IMAGE=
# ServiceAccount the orchestrated benchmark Jobs run under. The deploy sets this to the
# least-privilege SA the chart/base create; empty -> the namespace default SA (local dev).
ORCHESTRATOR_SERVICE_ACCOUNT=

# --- Simulate (dry run) -----------------------------------------------------
# When 1, the agent drives the WHOLE workflow but EXECUTES NOTHING: every command
# is a no-op returning synthetic success, per-command approvals are skipped, and a
# synthetic benchmark report is produced. Lets you watch the agent walk a guide
# end-to-end without touching a cluster. Default 0 (real execution).
SIMULATE=0
# --- API trust (Phase 12) — optional auth + rate-limit + CORS ---------------
# ALL THREE default OFF/open, so local single-user use is unchanged. Enable them only when
# exposing the API beyond localhost. See knowledge/api_trust.md for when/how.
#
# Bearer-token auth. When AUTH_ENABLED=true, every HTTP route and the /ws endpoint require
# `Authorization: Bearer <AUTH_TOKEN>` (WS may also pass it as ?token=...). Missing/bad -> 401.
# AUTH_TOKEN is a backend secret like the LLM keys; never echoed to the browser. Enabling auth
# with an empty token is a misconfiguration and the server refuses to start.
AUTH_ENABLED=false
AUTH_TOKEN=

# In-memory token-bucket rate limiter on the /api/* message-intake surface. RPS = steady refill
# rate (tokens/sec); BURST = bucket capacity (max instantaneous). Over budget -> HTTP 429.
# Per-process (not distributed). /healthz and /metrics are never throttled.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

# CORS: comma-separated allowed origins for the browser fetch surface. Empty (default) installs
# NO CORS middleware (today's behavior). e.g. CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_ORIGINS=

# --- Workspace lifecycle (Phase 18) — retention/GC + startup self-check ------
# Bound the growth of per-session/run scratch + the history store. Each cap applies independently
# per area (sessions/, runs/, jobs/, history/), removing the OLDEST first; 0 = UNLIMITED. An
# active/running session is NEVER pruned. Defaults DON'T surprise existing users: only a generous
# 500-items/area ceiling is on; age + bytes are unlimited (no time/size deletion out of the box).
# See knowledge/workspace_lifecycle.md. Set these to enable active reclamation to fit your disk.
RETENTION_MAX_AGE_DAYS=0
RETENTION_MAX_ITEMS=500
RETENTION_MAX_BYTES=0
# Run the retention GC once at startup (default true; a no-op under the defaults above).
RETENTION_GC_ON_STARTUP=true
# Run the startup config self-check (workspace writable, provider coherent, repos resolvable,
# auth coherent) and fold it into /readyz (200 ready / 503 not-ready, with structured reasons).
STARTUP_SELF_CHECK=true
