# Keep the build context lean and secret-free. The image is built from pyproject + app/ +
# the runtime data dirs only (see Dockerfile); everything below is either a secret, runtime
# scratch, local tooling, or docs that don't belong in the image.
#
# NOTE: scripts/ is NOT excluded — it now SHIPS in the image (the Dockerfile `COPY scripts
# ./scripts`), because the allowlist runs scripts/bridges/capacity_check.py + aggregate_runs.py +
# provision_hf_secret.py via the bundled CLI venv. Do not add a scripts/ exclusion here.

# Secrets — never copy .env (or any local override) into an image layer.
.env
.env.*
!.env.example

# Runtime scratch (per-session state, generated configs, captured logs, optional repo clones).
workspace/

# Local virtualenvs / build outputs.
.venv/
venv/
build/
dist/
*.egg-info/

# Python caches.
__pycache__/
*.py[cod]

# Tooling / test caches.
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Tests are not needed in the production image.
tests/

# Debug-only local mock-cluster harness (multi-node kind / kwok fake-GPU scaffolding used to
# exercise multi-GPU orchestration without real hardware). NEVER part of the product — the
# Dockerfile only COPYs the five runtime dirs (app, security, knowledge, ui, scripts), and
# tests/test_product_boundary.py enforces it.
testing/

# VCS + editor + OS noise.
.git/
.github/
.gitignore
.idea/
.vscode/
.DS_Store

# Docs / planning that don't belong in the image.
*.md
!README.md
docs/
