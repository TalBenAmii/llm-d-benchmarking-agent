# Claude Code worktrees — transient, per-session; never commit these
.claude/worktrees/

# Local-only QA-fleet skill (machine-specific tooling; not shared). Other .claude/ content
# (settings.json, workflows/, and other skills/) stays tracked.
.claude/skills/qa-fleet/

# Archived skills/workflows — retired from the active set, kept locally for reference only.
# Git history already preserves the deleted originals; no need to re-commit them here.
.claude/archive/

# Nested upstream repos — managed by their own git, not this one
/llm-d/
/llm-d-benchmark/
