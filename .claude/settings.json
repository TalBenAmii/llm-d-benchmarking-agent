{
  "permissions": {
    "deny": [
      "Edit(/llm-d-benchmark/**)",
      "Edit(/llm-d/**)",
      "Write(/llm-d-benchmark/**)",
      "Write(/llm-d/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/worktree_gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/git_add_guard.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/tool_lesson_inject.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/ruff_autofix.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/tool_error_capture.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/gpu_context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/auto_merge_worktree.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear|logout|other",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/reflect_session_end.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/llm-d-benchmarking-agent-project/.claude/hooks/context_sync.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {}
}
